---
import Header from "@components/ui/Header.astro";
import Footer from "@components/ui/Footer.astro";
import "@styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "profile";
  noindex?: boolean;
  canonicalPath?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  currentPath = Astro.url?.pathname || "/",
  image = "/seo/gymcat-og-image.png",
  imageAlt = "GymCat, comparador de gimnasios en Cataluña",
  type = "website",
  noindex = false,
  canonicalPath,
  structuredData,
} = Astro.props;

const siteUrl = "https://gymcat.es";
const defaultTitle = "GymCat — Comparador de Gimnasios en Cataluña";
const defaultDescription = "Compara precios reales, instalaciones y horarios de gimnasios en Cataluña. Transparencia total con datos actualizados por IA.";
const pageTitle = title
  ? /\bgymcat\b/i.test(title)
    ? title
    : `${title} | GymCat`
  : defaultTitle;
const pageDescription = description || defaultDescription;
const canonicalUrl = new URL(canonicalPath || Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const baseStructuredData: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "GymCat",
    url: siteUrl,
    description: defaultDescription,
    inLanguage: "es-ES",
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}/gimnasios?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "GymCat",
    url: siteUrl,
    logo: `${siteUrl}/GymCatLogo.png`,
    sameAs: ["https://gymcat.es/quienes-somos"],
  },
];
const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = [...baseStructuredData, ...pageStructuredData];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/GymCatLogo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600&family=Roboto+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="GymCat" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <slot name="head" />
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyC10drvzhIUxn0bkqg3YQGNhQ0y8Y-EJY4"></script>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-charcoal">
    <Header currentPath={currentPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;background:var(--color-white);border-top:1px solid rgba(34,42,53,0.1);padding:16px 24px;z-index:999;box-shadow:0 -4px 24px rgba(0,0,0,0.08);">
      <div class="container-xl" style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
        <p style="font-size:13px;color:var(--color-mid-gray);margin:0;flex:1;min-width:200px;line-height:1.5;">
          Usamos cookies t&eacute;cnicas necesarias y, con tu permiso, la geolocalizaci&oacute;n para gimnasios cercanos. <a href="/politica-de-cookies" style="color:var(--color-link-blue);">Info</a>
        </p>
        <div style="display:flex;gap:8px;flex-shrink:0;">
          <button onclick="rejectCookies()" class="btn-ghost" style="font-size:12px;padding:6px 14px;">Solo necesarias</button>
          <button onclick="acceptCookies()" class="btn-primary" style="font-size:12px;padding:6px 14px;">Aceptar</button>
        </div>
      </div>
    </div>
    <script is:inline>
      // Analytics tracking
      window._track = function(eventType, gymId, extra) {
        try {
          fetch('/api/analytics', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({event_type:eventType, gym_id:gymId, page:window.location.pathname, meta:extra||{}})
          }).catch(function(){});
        } catch(e) {}
      };
      if (window.location.pathname === '/') window._track('landing_view');
      if (window.location.pathname.indexOf('/admin') !== 0) window._track('page_view');

      // Cookie consent
      (function() {
        var consent = localStorage.getItem('cookie_consent');
        if (!consent) document.getElementById('cookie-banner').style.display = 'block';
        window.acceptCookies = function() {
          localStorage.setItem('cookie_consent', 'accepted');
          document.getElementById('cookie-banner').style.display = 'none';
          if (window._detectLocation) window._detectLocation();
        };
        window.rejectCookies = function() {
          localStorage.setItem('cookie_consent', 'rejected');
          document.getElementById('cookie-banner').style.display = 'none';
        };
      })();
    </script>
    <script is:inline defer src="https://cdn.vercel-insights.com/v1/script.js" data-endpoint="https://vercel.com/api/speed-insights/v1"></script>
    <script is:inline>
      window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </body>
</html>
