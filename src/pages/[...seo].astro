---
// Programmatic SEO: landing pages for cities and chains
// /gimnasios/[city] and /cadenas/[chain]
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { gyms, chains, cities, gymFacilities, facilities } from "@lib/db/schema";
import { eq, asc } from "drizzle-orm";

export const prerender = false;

const { seo } = Astro.params;
if (!seo) return Astro.redirect("/gimnasios");

// Determine if it's a city or chain page
const allCities = await db.select({ slug: cities.slug, name: cities.name }).from(cities);
const allChains = await db.select({ slug: chains.slug, name: chains.name, id: chains.id }).from(chains);

const cityMatch = allCities.find(c => c.slug === seo);
const chainMatch = allChains.find(c => c.slug === seo);

let title = "";
let description = "";
let filteredGyms: any[] = [];

if (cityMatch) {
  title = `Gimnasios en ${cityMatch.name} — Compara Precios | GymCat`;
  description = `Encuentra los mejores gimnasios en ${cityMatch.name}. Compara precios, instalaciones y horarios. ${cityMatch.name} al mejor precio.`;
  const cityData = await db.select({ id: cities.id }).from(cities).where(eq(cities.slug, seo)).limit(1);
  if (cityData.length > 0) {
    filteredGyms = await db.select().from(gyms).where(eq(gyms.cityId, cityData[0].id));
  }
} else if (chainMatch) {
  title = `Gimnasios ${chainMatch.name} — Precios y Opiniones | GymCat`;
  description = `Todos los gimnasios de ${chainMatch.name} en Cataluña. Compara precios, instalaciones y valoraciones. ¿Cuál es el mejor ${chainMatch.name}?`;
  filteredGyms = await db.select().from(gyms).where(eq(gyms.chainId, chainMatch.id));
} else {
  return Astro.redirect("/gimnasios");
}

const allFacilities = await db.select().from(facilities);
const gymsJSON = JSON.stringify(filteredGyms.map(g => ({
  id: g.id, name: g.name, slug: g.slug, address: g.address,
  imageUrl: g.imageUrl, chainId: g.chainId, cityId: g.cityId,
  monthlyPriceLow: g.monthlyPriceLow ? Number(g.monthlyPriceLow) : null,
  monthlyPriceHigh: g.monthlyPriceHigh ? Number(g.monthlyPriceHigh) : null,
  matriculaFee: g.matriculaFee ? Number(g.matriculaFee) : null,
  isOpen247: g.isOpen247,
})));
const facilitiesJSON = JSON.stringify(allFacilities.map(f => ({ id: f.id, name: f.name, slug: f.slug, icon: f.icon })));
const chainsJSON = JSON.stringify(allChains.map(c => ({ id: c.id, name: c.name, slug: c.slug })));
const citiesJSON = JSON.stringify(allCities.map(c => ({ id: c.id, name: c.name, slug: c.slug })));
---

<BaseLayout title={title} description={description}>
  <section class="res-section" style="background:var(--color-white);">
    <div class="container-xl">

      <div style="margin-bottom:24px;">
        <a href="/gimnasios" style="font-size:14px;font-weight:500;color:var(--color-link-blue);text-decoration:underline;">&larr; Todos los gimnasios</a>
      </div>

      <h1 style="margin-bottom:4px;">{title.replace(" | GymCat", "")}</h1>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);margin-bottom:24px;">{filteredGyms.length} gimnasios encontrados</p>

      <div class="res-grid res-grid-3" style="gap:16px;" id="gym-list">
        {filteredGyms.map(gym => {
          const chainN = chainMatch?.name || null;
          const cityN = cityMatch?.name || null;
          const price = gym.monthlyPriceLow ? Number(gym.monthlyPriceLow).toFixed(0) : null;
          return (
            <a href={`/gimnasios/${gym.slug}`} style="text-decoration:none;color:inherit;">
              <div class="card" style="display:flex;flex-direction:column;height:100%;transition:transform 0.15s;">
                {gym.imageUrl ? (
                  <img src={gym.imageUrl} alt={gym.name} style="width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--radius-8);margin-bottom:10px;" loading="lazy" />
                ) : (
                  <div style="width:100%;aspect-ratio:4/3;background:var(--color-off-white);border-radius:var(--radius-8);margin-bottom:10px;display:flex;align-items:center;justify-content:center;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/><path d="M12 5v14"/></svg>
                  </div>
                )}
                <h3 style="font-size:15px;font-weight:600;margin-bottom:4px;line-height:1.2;">{gym.name}</h3>
                {gym.address && <p style="font-size:12px;color:var(--color-mid-gray);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:6px;">{gym.address}</p>}
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;">
                  {price ? <span style="font-family:var(--font-mono);font-size:15px;font-weight:600;">{price}&euro;<span style="font-weight:300;font-size:12px;">/mes</span></span> : <span style="color:var(--color-mid-gray);font-size:13px;">Consultar</span>}
                  {gym.isOpen247 && <span style="font-size:11px;color:#22c55e;font-weight:500;">24h</span>}
                </div>
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </section>
</BaseLayout>
