---
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { settings } from "@lib/db/schema";

const all = await db.select().from(settings);
const getS = (key: string, def = "") => all.find(s => s.key === key)?.value || def;

const emailTo = getS("contact_email_to", "tovard799@gmail.com");

let message = "";
let messageType = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get("name")?.toString() || "";
    const email = formData.get("email")?.toString() || "";
    const subject = formData.get("subject")?.toString() || "Contacto GymCat";
    const body = formData.get("message")?.toString() || "";

    if (!name || !email || !body) {
      message = "Por favor completa todos los campos obligatorios.";
      messageType = "error";
    } else {
      const fullBody = `Nombre: ${name}\nEmail: ${email}\nAsunto: ${subject}\n\nMensaje:\n${body}`;

      // Try Resend API if configured
      const resendKey = getS("resend_api_key", "");
      let emailSent = false;
      if (resendKey) {
        try {
          const res = await fetch("https://api.resend.com/emails", {
            method: "POST",
            headers: { Authorization: `Bearer ${resendKey}`, "Content-Type": "application/json" },
            body: JSON.stringify({
              from: "GymCat <contacto@gymcat.es>",
              to: emailTo,
              subject: `GymCat: ${subject}`,
              text: fullBody,
            }),
          });
          emailSent = res.ok;
        } catch {}
      }

      // Fallback: save to /tmp (only writable dir on Vercel)
      if (!emailSent) {
        const { writeFileSync, mkdirSync } = await import("node:fs");
        const { join } = await import("node:path");
        const dir = join("/tmp", "gymcat-contact");
        mkdirSync(dir, { recursive: true });
        writeFileSync(join(dir, `contacto-${Date.now()}.txt`), fullBody);
      }

      message = "Mensaje enviado correctamente. Te responderemos pronto.";
      messageType = "success";
    }
  } catch (e: any) {
    message = `Error: ${e.message}`;
    messageType = "error";
  }
}
---

<BaseLayout title="Contacto" description="Contacta con GymCat. Dudas, sugerencias o colaboraciones." currentPath="/contacto">

<section class="res-section" style="background:var(--color-white);">
  <div class="container-xl">

    <div style="max-width:600px;margin:0 auto;">
      <h1 style="font-size:36px;font-weight:600;margin-bottom:8px;text-align:center;">Contacto</h1>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);letter-spacing:-0.2px;margin-bottom:32px;text-align:center;line-height:1.6;">
        &iquest;Tienes alguna duda, sugerencia o quieres colaborar? Escr&iacute;benos.
      </p>

      {message && (
        <div style={`padding:12px 16px;border-radius:var(--radius-8);margin-bottom:20px;font-size:14px;${messageType==='success'?'background:#dcfce7;color:#166534':'background:#fee2e2;color:#991b1b'}`}>
          {message}
        </div>
      )}

      <form method="POST" style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div>
            <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;">Nombre *</label>
            <input type="text" name="name" required placeholder="Tu nombre"
              style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:var(--radius-8);font-size:14px;font-family:inherit;">
          </div>
          <div>
            <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;">Email *</label>
            <input type="email" name="email" required placeholder="tu@email.com"
              style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:var(--radius-8);font-size:14px;font-family:inherit;">
          </div>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;">Asunto</label>
          <select name="subject" style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:var(--radius-8);font-size:14px;font-family:inherit;background:white;">
            <option value="Consulta general">Consulta general</option>
            <option value="Problema con un gimnasio">Problema con un gimnasio</option>
            <option value="Sugerencia">Sugerencia</option>
            <option value="Colaboraci&oacute;n">Colaboraci&oacute;n</option>
            <option value="Publicidad">Publicidad</option>
            <option value="A&ntilde;adir mi gimnasio">A&ntilde;adir mi gimnasio</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <div>
          <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;">Mensaje *</label>
          <textarea name="message" required placeholder="Escribe tu mensaje aqu&iacute;..."
            style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:var(--radius-8);font-size:14px;font-family:inherit;min-height:140px;resize:vertical;"></textarea>
        </div>

        <button type="submit" class="btn-primary" style="padding:14px 28px;font-size:15px;">Enviar mensaje</button>
      </form>

      <div style="margin-top:32px;padding-top:24px;border-top:1px solid rgba(34,42,53,0.06);display:flex;flex-direction:column;gap:12px;align-items:center;">
        <p style="font-size:13px;font-weight:500;color:var(--color-charcoal);">Tambi&eacute;n puedes escribirnos directamente:</p>
        <a href={`mailto:${emailTo}`} style="display:inline-flex;align-items:center;gap:6px;font-size:15px;font-weight:600;color:var(--color-link-blue);text-decoration:underline;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><polyline points="2 5 12 12 22 5"/></svg>
          {emailTo}
        </a>
      </div>
    </div>

  </div>
</section>

</BaseLayout>
