---
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { gyms, chains, cities } from "@lib/db/schema";
import { desc } from "drizzle-orm";

const latestGym = await db.select({ updatedAt: gyms.updatedAt }).from(gyms).orderBy(desc(gyms.updatedAt)).limit(1);
const allGyms = await db.select({ id: gyms.id }).from(gyms);
const allChains = await db.select({ id: chains.id }).from(chains);
const allCities = await db.select({ id: cities.id }).from(cities);
const lastUpdate = latestGym[0]?.updatedAt
  ? new Date(latestGym[0].updatedAt).toISOString().split("T")[0]
  : new Date().toISOString().split("T")[0];
---

<BaseLayout title="GymCat — Comparador Inteligente de Gimnasios" description="Encuentra el gimnasio perfecto. Busca por precio, ubicación y servicios con IA.">
  <section class="bg-white" style="padding:64px 0 48px 0;">
    <div class="container-xl" style="text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:6px;border-radius:var(--radius-pill);padding:4px 14px;font-size:13px;font-weight:500;color:var(--color-mid-gray);background:var(--color-off-white);margin-bottom:20px;">
        <span style="width:7px;height:7px;border-radius:50%;background:#22c55e;display:inline-block;"></span> &Uacute;ltima actualizaci&oacute;n: {lastUpdate}
      </div>
      <h1 style="margin-bottom:12px;">El gimnasio que buscas,<br/>sin letra pequeña.</h1>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);max-width:480px;margin:0 auto 24px;line-height:1.6;letter-spacing:-0.1px;">
        Compara precios reales, instalaciones y horarios de cientos de gimnasios en Cataluña. Datos actualizados por IA.
      </p>
      <form id="search-form" style="max-width:500px;margin:0 auto 20px;" onsubmit="return handleSearch(event)">
        <div style="padding:14px 18px;background:var(--color-white);border-radius:var(--radius-12);box-shadow:var(--shadow-card);display:flex;align-items:center;gap:10px;cursor:text;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-mid-gray)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" name="q" id="search-input"
            placeholder="Buscar gimnasios..."
            style="flex:1;border:none;outline:none;font-size:14px;font-family:var(--font-body);color:var(--color-charcoal);background:transparent;"
            autocomplete="off" />
          <button type="submit" style="background:var(--color-charcoal);color:white;border:none;padding:6px 14px;border-radius:var(--radius-6);font-size:13px;font-weight:500;cursor:pointer;">Buscar</button>
        </div>
      </form>
      <p id="search-hint" style="font-size:12px;color:var(--color-mid-gray);margin-top:-12px;margin-bottom:12px;">Ej: "con piscina cerca de Sants por menos de 40€"</p>
      <div id="search-loading" style="display:none;margin-bottom:12px;font-size:13px;color:var(--color-mid-gray);">Buscando con IA...</div>
      <div class="res-flex-col" style="justify-content:center;">
        <a href="/gimnasios" class="btn-primary" style="min-width:180px;text-decoration:none;text-align:center;">Explorar gimnasios</a>
        <a href="/vs" class="btn-ghost" style="min-width:140px;text-decoration:none;text-align:center;">Comparar VS</a>
      </div>
    </div>
  </section>

  <section style="padding:48px 0;background:var(--color-off-white);">
    <div class="container-xl">
      <div style="text-align:center;margin-bottom:32px;">
        <h2 style="margin-bottom:8px;">Transparencia que ningún<br class="hide-mobile"/>gimnasio te dará</h2>
        <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);max-width:420px;margin:0 auto;">Datos objetivos, sin marketing.</p>
      </div>
      <div class="res-grid res-grid-3" style="gap:12px;">
        <div class="card" style="border:2px solid var(--color-charcoal);box-shadow:0 0 0 2px rgba(36,36,36,0.05),var(--shadow-card);"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 8 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8z"/></svg><h3 style="margin-bottom:4px;">Visitamos cada gimnasio</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Hemos estado en todos los gimnasios que aparecen en la web. Verificamos instalaciones, limpieza y ambiente real.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="7" y1="21" x2="7" y2="9"/></svg><h3 style="margin-bottom:4px;">Historial de Precios</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Gr&aacute;ficos que muestran c&oacute;mo han cambiado los precios. Detecta falsas ofertas al instante.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg><h3 style="margin-bottom:4px;">Coste Real a 12 Meses</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Matr&iacute;cula + mensualidad + mantenimiento. Sin sorpresas.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg><h3 style="margin-bottom:4px;">Resumen de todas las Rese&ntilde;as</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Resumimos cientos de rese&ntilde;as extrayendo pros y contras.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><h3 style="margin-bottom:4px;">Comparador VS</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Dos gimnasios cara a cara. Precios, instalaciones y penalizaciones.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg><h3 style="margin-bottom:4px;">Sin letra peque&ntilde;a</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Mostramos matr&iacute;cula, mantenimiento anual, penalizaciones y coste total. Todo transparente.</p></div>
      </div>
    </div>
  </section>

  <section style="padding:32px 0;border-top:1px solid rgba(34,42,53,0.08);border-bottom:1px solid rgba(34,42,53,0.08);">
    <div class="container-xl">
      <div class="res-grid res-grid-4" style="gap:16px;text-align:center;max-width:600px;margin:0 auto;">
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">{allGyms.length}</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Gimnasios</div></div>
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">{allChains.length}</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Cadenas</div></div>
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">{allCities.length}</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Ciudades</div></div>
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">100+</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Rese&ntilde;as IA</div></div>
      </div>
    </div>
  </section>

  <section style="padding:48px 0 64px 0;background:var(--color-white);">
    <div class="container-xl" style="text-align:center;">
      <h2 style="margin-bottom:8px;">¿Tienes un gimnasio?</h2>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);margin-bottom:20px;">Añadimos tus datos sin coste.</p>
      <a href="mailto:hola@gymcat.es" class="btn-primary" style="min-width:180px;text-decoration:none;">Contactar &rarr;</a>
    </div>
  </section>

  <script is:inline>
    async function handleSearch(e) {
      e.preventDefault();
      var q = document.getElementById('search-input').value.trim();
      if (!q) { window.location = '/gimnasios'; return false; }
      document.getElementById('search-loading').style.display = 'block';
      try {
        var res = await fetch('/api/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: q })
        });
        var data = await res.json();
        var f = data.filters || {};
        var params = new URLSearchParams();
        // Only set search bar text if AI detected a gym name (short query)
        if (data.searchBarText) params.set('q', data.searchBarText);
        if (f.facilities && f.facilities.length) params.set('fac', f.facilities.join(','));
        if (f.is24h) params.set('24h', '1');
        if (f.maxPrice) params.set('max', f.maxPrice);
        if (f.sortBy && f.sortBy !== 'relevance') params.set('sort', f.sortBy);
        if (f.city) params.set('city', f.city);
        var url = '/gimnasios?' + params.toString();
        window.location = url;
      } catch(err) {
        window.location = '/gimnasios?q=' + encodeURIComponent(q);
      }
      return false;
    }
  </script>
</BaseLayout>
