---
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { gyms, chains } from "@lib/db/schema";
import { eq, asc } from "drizzle-orm";

const allGyms = await db
  .select({
    id: gyms.id, name: gyms.name, slug: gyms.slug,
    address: gyms.address, imageUrl: gyms.imageUrl,
    lat: gyms.lat, lng: gyms.lng,
    monthlyPriceLow: gyms.monthlyPriceLow, isOpen247: gyms.isOpen247,
    chainId: gyms.chainId,
  })
  .from(gyms)
  .where(eq(gyms.status, "active"))
  .orderBy(asc(gyms.name));

const allChains = await db.select().from(chains);
const chainMap = new Map(allChains.map(c => [c.id, c]));

const gymsJSON = JSON.stringify(allGyms.map(g => ({
  id: g.id, name: g.name, slug: g.slug, address: g.address,
  imageUrl: g.imageUrl, lat: g.lat ? Number(g.lat) : null, lng: g.lng ? Number(g.lng) : null,
  chain: g.chainId ? chainMap.get(g.chainId)?.name : null,
  chainSlug: g.chainId ? chainMap.get(g.chainId)?.slug : null,
  priceFrom: g.monthlyPriceLow ? Number(g.monthlyPriceLow) : null,
  is24h: g.isOpen247,
})));

const chainsJSON = JSON.stringify(allChains.map(c => ({ id: c.id, name: c.name, slug: c.slug })));
---

<BaseLayout title="Mapa de Gimnasios" currentPath="/mapa">
  <section class="map-page">
    <style>
      .map-page { padding: 64px 0 0; min-height: 100vh; display: flex; flex-direction: column; }
      .map-header { padding: 0 24px; margin-bottom: 16px; max-width: 1200px; width: 100%; margin-left: auto; margin-right: auto; }
      .map-header h1 { font-size: 36px; font-weight: 600; color: #242424; margin-bottom: 4px; }
      .map-header p { font-size: 16px; font-weight: 300; color: #898989; letter-spacing: -0.2px; margin-bottom: 12px; }
      .map-filters { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
      .map-filters select, .map-filters label { padding: 6px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; background: white; font-family: inherit; cursor: pointer; }
      .map-container { flex: 1; width: 100%; min-height: 500px; position: relative; }
      #map { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }
      @media (max-width: 640px) {
        .map-header h1 { font-size: 24px; }
        .map-page { padding-top: 80px; }
      }
    </style>

    <div class="map-header">
      <h1>Mapa de gimnasios</h1>
      <p>{allGyms.length} gimnasios en el mapa. Filtra por precio, cadena y horario.</p>
      <div class="map-filters" id="filters">
        <select id="filterChain">
          <option value="">Todas las cadenas</option>
          {allChains.map(c => <option value={c.slug}>{c.name}</option>)}
        </select>
        <select id="filterPrice">
          <option value="">Cualquier precio</option>
          <option value="0-25">Hasta 25€/mes</option>
          <option value="25-40">25€ – 40€/mes</option>
          <option value="40-60">40€ – 60€/mes</option>
          <option value="60-100">Más de 60€/mes</option>
        </select>
        <label><input type="checkbox" id="filter24h" style="width:auto;"> 24h</label>
        <span style="font-size:13px;color:#888;margin-left:8px;" id="resultCount"></span>
      </div>
    </div>

    <div class="map-container"><div id="map"></div></div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ gymsJSON, chainsJSON }}>
  (function() {
    var gyms = JSON.parse(gymsJSON);
    var chainsData = JSON.parse(chainsJSON);

    function initMap() {
      if (typeof L === 'undefined') { setTimeout(initMap, 100); return; }

      var map = L.map('map').setView([41.3874, 2.1686], 13);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors', maxZoom: 19
      }).addTo(map);

      var markers = [];

      gyms.forEach(function(gym, i) {
        if (!gym.lat || !gym.lng) return;
        var priceStr = gym.priceFrom ? gym.priceFrom.toFixed(0) + '€/mes' : 'Precio no disponible';
        var popup = '<div style="font-family:system-ui;max-width:250px;">';
        if (gym.imageUrl) popup += '<img src="' + gym.imageUrl + '" style="width:100%;height:100px;object-fit:cover;border-radius:4px;margin-bottom:8px;" />';
        popup += '<h3 style="margin:0 0 4px;font-size:15px;"><a href="/gimnasios/' + gym.slug + '" style="color:#242424;text-decoration:none;">' + gym.name + '</a></h3>';
        if (gym.chain) popup += '<span style="font-size:11px;color:#888;background:#f0f0f0;padding:2px 8px;border-radius:10px;">' + gym.chain + '</span>';
        popup += '<p style="margin:6px 0;font-family:monospace;font-weight:600;">' + priceStr + '</p>';
        if (gym.is24h) popup += '<span style="font-size:11px;color:#22c55e;">24h</span> ';
        popup += '<p style="margin:4px 0 0;font-size:12px;color:#888;">' + (gym.address || '') + '</p>';
        popup += '<a href="/gimnasios/' + gym.slug + '" style="display:inline-block;margin-top:8px;font-size:12px;color:#0099ff;">Ver ficha &rarr;</a></div>';

        var marker = L.marker([gym.lat, gym.lng]).bindPopup(popup);
        marker._gym = gym;
        marker.addTo(map);
        markers.push(marker);
      });

      document.getElementById('resultCount').textContent = markers.length + ' gimnasios visibles';

      if (markers.length > 0) {
        var group = L.featureGroup ? L.featureGroup(markers) : null;
        if (group) map.fitBounds(group.getBounds().pad(0.1));
      }

      function getRange(p) {
        if (p === null || p === undefined) return '?';
        if (p <= 25) return '0-25';
        if (p <= 40) return '25-40';
        if (p <= 60) return '40-60';
        return '60-100';
      }

      function applyFilters() {
        var chainFilter = document.getElementById('filterChain').value;
        var priceFilter = document.getElementById('filterPrice').value;
        var filter24h = document.getElementById('filter24h').checked;
        var count = 0;
        markers.forEach(function(m) {
          var g = m._gym;
          var show = true;
          if (chainFilter && g.chainSlug !== chainFilter) show = false;
          if (priceFilter && getRange(g.priceFrom) !== priceFilter) show = false;
          if (filter24h && !g.is24h) show = false;
          if (show) { m.addTo(map); count++; } else { m.remove(); }
        });
        document.getElementById('resultCount').textContent = count + ' gimnasios visibles';
      }

      document.getElementById('filterChain').addEventListener('change', applyFilters);
      document.getElementById('filterPrice').addEventListener('change', applyFilters);
      document.getElementById('filter24h').addEventListener('change', applyFilters);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMap);
    } else {
      initMap();
    }
  })();
</script>
