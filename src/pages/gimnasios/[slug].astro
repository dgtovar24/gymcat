---
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { gyms, pricesHistory, gymFacilities, facilities, gymImages, chains, cities } from "@lib/db/schema";
import { eq, desc, asc } from "drizzle-orm";

export const prerender = false;
const { slug } = Astro.params;
if (!slug) return Astro.redirect("/gimnasios");

const gymResults = await db.select().from(gyms).where(eq(gyms.slug, slug)).limit(1);
const gym = gymResults[0];
if (!gym) return new Response("Gimnasio no encontrado", { status: 404 });

const gymPrices = await db.select().from(pricesHistory).where(eq(pricesHistory.gymId, gym.id)).orderBy(desc(pricesHistory.recordedAt)).limit(20);
const gymFacilityRows = await db.select({ facility: facilities }).from(gymFacilities).innerJoin(facilities, eq(gymFacilities.facilityId, facilities.id)).where(eq(gymFacilities.gymId, gym.id));
const images = await db.select().from(gymImages).where(eq(gymImages.gymId, gym.id)).orderBy(asc(gymImages.sortOrder));
const chain = gym.chainId ? (await db.select().from(chains).where(eq(chains.id, gym.chainId)).limit(1))[0] : null;
const city = gym.cityId ? (await db.select().from(cities).where(eq(cities.id, gym.cityId)).limit(1))[0] : null;
const monthlyLow = gym.monthlyPriceLow ? Number(gym.monthlyPriceLow) : 0;
const matricula = gym.matriculaFee ? Number(gym.matriculaFee) : 0;
const annualMaint = gym.annualMaintenanceFee ? Number(gym.annualMaintenanceFee) : 0;
const total12Months = (monthlyLow * 12) + matricula + annualMaint;
const pageTitle = `${gym.name} — Precios, instalaciones y opiniones | Gymcat`;
const pageDescription = gym.shortDescription || `${gym.name} en ${city?.name || "Cataluña"}. Precio desde ${monthlyLow}€/mes.`;

// Coordinates for map
const gymLat = gym.lat ? Number(gym.lat) : 0;
const gymLng = gym.lng ? Number(gym.lng) : 0;
const hasCoords = gymLat !== 0 && gymLng !== 0;

// Sparkline
const maxPrice = Math.max(...gymPrices.map(x => Number(x.amount)), 1);
const sparkBars = gymPrices.slice(0, 20).reverse().map(p => ({
  h: Math.max((Number(p.amount) / maxPrice) * 100, 4),
  active: Number(p.amount) === monthlyLow,
  price: Number(p.amount).toFixed(0),
}));

// Facility icons mapped to SVGs
const facIcons: Record<string, string> = {
  "🏋️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/><path d="M12 5v14"/></svg>',
  "🏋️‍♂️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/></svg>',
  "🏃": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><path d="M10 22v-5l-2-4"/><path d="M14 22v-5l2-4"/></svg>',
  "🔧": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  "🏗️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><path d="M6 10v10"/><path d="M12 10v10"/><path d="M18 10v10"/></svg>',
  "🏊": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 16c1.5 0 3-2 5-2s3.5 2 5 2 3-2 4-2"/><path d="M12 8V5l-3 1.5"/></svg>',
  "💆": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><path d="M8 14c0-2 1.5-3 4-3s4 1 4 3"/><path d="M12 22v-5"/></svg>',
  "🧖": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h16"/><path d="M6 16l-2-4h16l-2 4"/><path d="M12 4v6"/></svg>',
  "♨️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 4v4m0 4v4"/><path d="M8 4h8M8 8h8M8 12h8M8 16h8M8 20h8"/></svg>',
  "🛁": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V5a2 2 0 0 1 2-2h3v2.25"/></svg>',
  "👯": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="5" r="2"/><circle cx="16" cy="5" r="2"/><path d="M5 22v-7l2-4h10l2 4v7"/></svg>',
  "🚴": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="17" r="3"/><circle cx="18" cy="17" r="3"/><path d="M12 17V7l-3-3"/><path d="M15 4h4v4"/></svg>',
  "🧘": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="3" r="1"/><path d="M8 20l4-8 4 8"/><path d="M12 12v-4"/></svg>',
  "🤸": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="4" r="2"/><path d="M8 20l4-6 4 6"/></svg>',
  "💪": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 7V3H7v4"/><path d="M7 13v4h10v-4"/><path d="M17 7a5 5 0 0 1 0 10"/><path d="M7 7a5 5 0 0 0 0 10"/></svg>',
  "🥊": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="8" r="5"/><circle cx="16" cy="8" r="5"/></svg>',
  "💃": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="4" r="2"/><path d="M12 6v12"/><path d="M8 14l4-2 4 2"/></svg>',
  "🏋️‍♀️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/></svg>',
  "🅿️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="12" y="16" text-anchor="middle" font-size="12" font-weight="bold" fill="currentColor" stroke="none">P</text></svg>',
  "👶": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2"/></svg>',
  "☕": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>',
  "🧺": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18l-3 12H6L3 6z"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/></svg>',
  "🔐": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
  "📶": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1"/></svg>',
  "📱": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>',
  "🕐": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  "♾️": '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 12c-2-2.67-4-4-6-4a4 4 0 1 0 0 8c2 0 4-1.33 6-4zm0 0c2 2.67 4 4 6 4a4 4 0 0 0 0-8c-2 0-4 1.33-6 4z"/></svg>',
};

function facIcon(icon: string | null) {
  if (!icon) return "";
  return facIcons[icon] || icon;
}
---

<BaseLayout title={pageTitle} description={pageDescription} currentPath="/gimnasios">
  <section style="padding:40px 0 0 0;background:var(--color-white);">
    <div class="container-xl">
      <a href="/gimnasios" style="font-size:14px;font-weight:500;color:var(--color-link-blue);text-decoration:underline;">&larr; Volver al listado</a>
    </div>
  </section>

  <section style="padding:16px 0 0 0;background:var(--color-white);">
    <div class="container-xl">
      <div class="mkt-grid">
        <!-- LEFT: Gallery -->
        <div>
          {images.length > 0 ? (
            <div>
              <div style="position:relative;background:#0a0a0a;border-radius:var(--radius-12);overflow:hidden;aspect-ratio:4/3;box-shadow:var(--shadow-card);">
                <img id="gallery-main-img" src={images[0]!.imageUrl} alt={gym.name} style="width:100%;height:100%;object-fit:cover;display:block;" />
                {images.length > 1 && (<>
                  <button id="gallery-prev" onclick="window._galleryNav(-1)" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.9);color:#242424;border:none;width:36px;height:36px;border-radius:50%;font-size:18px;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.15);">&lsaquo;</button>
                  <button id="gallery-next" onclick="window._galleryNav(1)" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.9);color:#242424;border:none;width:36px;height:36px;border-radius:50%;font-size:18px;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.15);">&rsaquo;</button>
                  <div id="gallery-counter" style="position:absolute;bottom:10px;right:14px;background:rgba(0,0,0,0.55);color:white;padding:3px 10px;border-radius:10px;font-size:12px;">1 / {images.length}</div>
                </>)}
              </div>
              {images.length > 1 && (
                <div style="display:flex;gap:6px;margin-top:8px;overflow-x:auto;">
                  {images.map((img, i) => (
                    <button onclick={`window._galleryGo(${i})`} style={`flex-shrink:0;width:56px;height:42px;border-radius:6px;overflow:hidden;border:2px solid ${i===0?'var(--color-charcoal)':'transparent'};cursor:pointer;padding:0;background:none;`} class="gthumb" data-index={i}>
                      <img src={img.imageUrl} alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
                    </button>
                  ))}
                </div>
              )}
            </div>
          ) : (
            <div style="aspect-ratio:4/3;background:var(--color-off-white);border-radius:var(--radius-12);display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-card);">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/><path d="M12 5v14"/></svg>
            </div>
          )}
        </div>

        <!-- RIGHT: Info -->
        <div>
          {chain && <span style="display:inline-block;font-size:12px;font-weight:500;color:var(--color-mid-gray);padding:3px 12px;border-radius:var(--radius-pill);box-shadow:var(--shadow-ring-border);margin-bottom:12px;">{chain.name}</span>}
          <h1 style="font-size:28px;font-weight:600;line-height:1.15;color:var(--color-charcoal);margin-bottom:6px;">{gym.name}</h1>
          {gym.address && <p style="font-size:14px;font-weight:400;color:var(--color-mid-gray);margin-bottom:4px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:2px;"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 8 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8z"/></svg> {gym.address}{city ? `, ${city.name}` : ""}</p>}
          {gym.isOpen247 && <span style="display:inline-block;font-size:12px;font-weight:500;color:#22c55e;padding:2px 10px;border-radius:var(--radius-pill);background:rgba(34,197,94,0.1);margin-bottom:16px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" style="vertical-align:-2px;margin-right:3px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Abierto 24h</span>}

          <div style="margin:16px 0 20px 0;padding:16px 0;border-top:1px solid rgba(34,42,53,0.08);border-bottom:1px solid rgba(34,42,53,0.08);">
            <div style="display:flex;align-items:baseline;gap:6px;">
              <span style="font-family:var(--font-mono);font-size:32px;font-weight:600;color:var(--color-charcoal);line-height:1;">{monthlyLow.toFixed(0)}&euro;</span>
              <span style="font-size:14px;font-weight:300;color:var(--color-mid-gray);">/mes</span>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:6px;font-size:13px;color:var(--color-mid-gray);">
              {matricula > 0 ? <span>Matr&iacute;cula: <strong style="color:var(--color-charcoal);">{matricula.toFixed(0)}&euro;</strong></span> : <span style="color:#22c55e;">Sin matr&iacute;cula</span>}
              {annualMaint > 0 && <span>Mant. anual: <strong style="color:var(--color-charcoal);">{annualMaint.toFixed(0)}&euro;</strong></span>}
            </div>
          </div>

          {gym.description && <p style="font-size:14px;font-weight:300;color:var(--color-mid-gray);line-height:1.6;margin-bottom:16px;">{gym.description}</p>}

          {gymFacilityRows.length > 0 && (
            <div style="margin-bottom:16px;">
              <h4 style="font-size:13px;font-weight:600;color:var(--color-charcoal);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">Instalaciones</h4>
              <div style="display:flex;flex-wrap:wrap;gap:5px;">
                {gymFacilityRows.map(row => <span class="fac-pill" style="display:inline-flex;align-items:center;gap:4px;"><span set:html={facIcon(row.facility.icon)}></span> {row.facility.name}</span>)}
              </div>
            </div>
          )}

          <div class="res-flex-col">
            {gym.website && <a href={gym.website} target="_blank" rel="noopener" class="btn-primary" style="text-decoration:none;flex:1;text-align:center;">Visitar web &rarr;</a>}
            {gym.phone && <a href={`tel:${gym.phone}`} class="btn-ghost" style="text-decoration:none;flex:1;text-align:center;display:inline-flex;align-items:center;justify-content:center;gap:4px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg> {gym.phone}</a>}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Bottom: Cost + Reviews -->
  <section style="padding:40px 0 64px 0;background:var(--color-off-white);">
    <div class="container-xl">
      <div class="bottom-grid">
        <div class="card">
          <h3 style="font-weight:600;color:var(--color-charcoal);margin-bottom:16px;display:flex;align-items:center;gap:6px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg>
            Coste real del primer a&ntilde;o
          </h3>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(34,42,53,0.05);"><span style="font-size:14px;color:var(--color-charcoal);">Mensualidad &times; 12</span><span class="mono" style="font-size:14px;">{(monthlyLow * 12).toFixed(0)}&euro;</span></div>
            {matricula > 0 ? <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(34,42,53,0.05);"><span style="font-size:14px;color:var(--color-mid-gray);">+ Matr&iacute;cula</span><span class="mono" style="font-size:14px;">{matricula.toFixed(0)}&euro;</span></div> : <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(34,42,53,0.05);"><span style="font-size:14px;color:#22c55e;">+ Matr&iacute;cula</span><span class="mono" style="font-size:14px;color:#22c55e;">0&euro;</span></div>}
            {annualMaint > 0 && <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(34,42,53,0.05);"><span style="font-size:14px;color:var(--color-mid-gray);">+ Mant. anual</span><span class="mono" style="font-size:14px;">{annualMaint.toFixed(0)}&euro;</span></div>}
            <div style="display:flex;justify-content:space-between;padding:12px 0 0 0;margin-top:4px;border-top:2px solid var(--color-charcoal);"><span style="font-family:var(--font-display);font-size:17px;font-weight:600;">Total primer a&ntilde;o</span><span class="mono" style="font-size:20px;">{total12Months.toFixed(0)}&euro;</span></div>
          </div>
          {gymPrices.length > 1 && (
            <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(34,42,53,0.06);">
              <h6 style="margin-bottom:6px;">HISTORIAL DE PRECIOS</h6>
              <div style="display:flex;align-items:flex-end;gap:2px;height:50px;">
                {sparkBars.map((bar) => <div style={`flex:1;background:${bar.active?'var(--color-charcoal)':'rgba(34,42,53,0.15)'};height:${bar.h}%;border-radius:2px 2px 0 0;`} title={`${bar.price}€`}></div>)}
              </div>
              <p style="font-size:11px;color:var(--color-mid-gray);margin-top:4px;">{gymPrices.length} registros</p>
            </div>
          )}
        </div>

        <div class="card">
          {(gym.aiSummaryPros?.length || gym.aiSummaryCons?.length) ? (<>
            <h3 style="font-weight:600;color:var(--color-charcoal);margin-bottom:2px;display:flex;align-items:center;gap:6px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg>
              Resumen de rese&ntilde;as
            </h3>
            <p style="font-size:12px;font-weight:300;color:var(--color-mid-gray);margin-bottom:16px;">Analizado por IA desde Google Maps</p>
            {gym.aiSummaryPros && gym.aiSummaryPros.length > 0 && (<div style="margin-bottom:14px;"><h4 style="font-size:14px;font-weight:600;color:#22c55e;margin-bottom:8px;display:flex;align-items:center;gap:4px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Lo mejor</h4><ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">{gym.aiSummaryPros.map((pro: string) => <li style="font-size:13px;padding-left:16px;position:relative;line-height:1.5;"><span style="position:absolute;left:0;color:#22c55e;">&rsaquo;</span> {pro}</li>)}</ul></div>)}
            {gym.aiSummaryCons && gym.aiSummaryCons.length > 0 && (<div><h4 style="font-size:14px;font-weight:600;color:#ef4444;margin-bottom:8px;display:flex;align-items:center;gap:4px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> A mejorar</h4><ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;">{gym.aiSummaryCons.map((con: string) => <li style="font-size:13px;padding-left:16px;position:relative;line-height:1.5;"><span style="position:absolute;left:0;color:#ef4444;">&rsaquo;</span> {con}</li>)}</ul></div>)}
          </>) : (<div style="text-align:center;padding:32px 0;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" style="margin-bottom:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h4v4"/><circle cx="12" cy="8" r="0.5"/></svg><p style="font-size:14px;color:var(--color-mid-gray);">A&uacute;n no hay rese&ntilde;as analizadas.</p></div>)}
        </div>
      </div>
    </div>
  </section>

  {hasCoords && (
    <div style="margin-top:32px;">
      <h4 style="font-size:13px;font-weight:600;color:var(--color-charcoal);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;">Ubicaci&oacute;n</h4>
      <div id="gym-map" data-map-lat={gymLat} data-map-lng={gymLng} data-map-name={gym.name}
        style="width:100%;height:280px;border-radius:var(--radius-12);overflow:hidden;box-shadow:var(--shadow-card);"></div>
      <script src="/map-init.js" defer></script>
    </div>
  )}

  {images.length > 1 && (
    <script is:inline define:vars={{ images: images.map(i => i.imageUrl) }}>
      const galleryImages = images; let currentIdx = 0;
      window._galleryNav = function(dir) { currentIdx = (currentIdx + dir + galleryImages.length) % galleryImages.length; updateGallery(); };
      window._galleryGo = function(idx) { currentIdx = idx; updateGallery(); };
      function updateGallery() {
        const img = document.getElementById('gallery-main-img'); if (img) img.src = galleryImages[currentIdx];
        const counter = document.getElementById('gallery-counter'); if (counter) counter.textContent = (currentIdx + 1) + ' / ' + galleryImages.length;
        document.querySelectorAll('.gthumb').forEach((t, i) => { t.style.borderColor = i === currentIdx ? 'var(--color-charcoal)' : 'transparent'; });
      }
      document.addEventListener('keydown', function(e) { if (e.key === 'ArrowLeft') window._galleryNav(-1); if (e.key === 'ArrowRight') window._galleryNav(1); });
    </script>
  )}
</BaseLayout>
