---
import BaseLayout from "@layouts/BaseLayout.astro";
import { db } from "@lib/db";
import { gyms, chains, facilities, gymFacilities } from "@lib/db/schema";
import { eq, asc } from "drizzle-orm";

// Single query: load all gyms once
const allGyms = await db.select({
  id: gyms.id, name: gyms.name, slug: gyms.slug, address: gyms.address,
  monthlyPriceLow: gyms.monthlyPriceLow, monthlyPriceHigh: gyms.monthlyPriceHigh,
  matriculaFee: gyms.matriculaFee, isOpen247: gyms.isOpen247,
  imageUrl: gyms.imageUrl, chainId: gyms.chainId,
  isVerified: gyms.isVerified, verifiedReview: gyms.verifiedReview,
}).from(gyms).where(eq(gyms.status, "active")).orderBy(asc(gyms.name));

const [allChains, allFacs, allGymFacRows] = await Promise.all([
  db.select().from(chains),
  db.select().from(facilities),
  db.select({ gymId: gymFacilities.gymId, facilityId: gymFacilities.facilityId }).from(gymFacilities),
]);

const chainMap = new Map(allChains.map(c => [c.id, c]));

// Build gym-facility map
const gymFacMap = new Map<number, string[]>();
for (const r of allGymFacRows) {
  if (!gymFacMap.has(r.gymId)) gymFacMap.set(r.gymId, []);
  const fac = allFacs.find(f => f.id === r.facilityId);
  if (fac) gymFacMap.get(r.gymId)!.push(fac.slug);
}

// Province mapping for cities
const cityProvince: Record<string, string> = {
  Barcelona: "Barcelona", "L'Hospitalet de Llobregat": "Barcelona", Badalona: "Barcelona",
  Terrassa: "Barcelona", Sabadell: "Barcelona", Mataró: "Barcelona",
  "Sant Cugat del Vallès": "Barcelona", "Cornellà de Llobregat": "Barcelona",
  Granollers: "Barcelona", Manresa: "Barcelona", Vic: "Barcelona",
  Sitges: "Barcelona", Castelldefels: "Barcelona", "El Prat de Llobregat": "Barcelona",
  Tarragona: "Tarragona", Reus: "Tarragona",
  Lleida: "Lleida",
  Girona: "Girona", Figueres: "Girona", Blanes: "Girona",
};

// Serialize data for client
const gymsJSON = JSON.stringify(allGyms.map(g => ({
  id: g.id, name: g.name, slug: g.slug, address: g.address,
  price: g.monthlyPriceLow ? Number(g.monthlyPriceLow) : null,
  priceHigh: g.monthlyPriceHigh ? Number(g.monthlyPriceHigh) : null,
  matricula: g.matriculaFee ? Number(g.matriculaFee) : null,
  is24h: g.isOpen247, image: g.imageUrl,
  isVerified: g.isVerified, verifiedReview: g.verifiedReview,
  chain: g.chainId ? chainMap.get(g.chainId)?.name || null : null,
  facilities: gymFacMap.get(g.id) || [],
})));

const provinces = ["Barcelona", "Tarragona", "Lleida", "Girona"];

const chainsJSON = JSON.stringify(allChains.map(c => ({ id: c.id, name: c.name, slug: c.slug })));
const facsJSON = JSON.stringify(allFacs.map(f => ({ id: f.id, name: f.name, slug: f.slug })));

// SVG icon map
// Used in data attributes — TS can't track
void (gymsJSON); void (chainsJSON); void (facsJSON);
const facSVGs: Record<string, string> = {
  pesas: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/></svg>',
  cardio: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><path d="M10 22v-5l-2-4"/><path d="M14 22v-5l2-4"/></svg>',
  'peso-libre': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l-3 3 3 3"/><path d="M18 9l3 3-3 3"/><path d="M12 5v14"/></svg>',
  funcional: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>',
  'power-rack': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><path d="M6 10v10"/><path d="M12 10v10"/><path d="M18 10v10"/></svg>',
  piscina: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 16c1.5 0 3-2 5-2s3.5 2 5 2 3-2 4-2"/><path d="M12 8V5l-3 1.5"/></svg>',
  spa: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2"/></svg>',
  sauna: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h16"/><path d="M6 16l-2-4h16l-2 4"/></svg>',
  'bano-turco': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"/></svg>',
  jacuzzi: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"/></svg>',
  'clases-dirigidas': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="5" r="2"/><circle cx="16" cy="5" r="2"/><path d="M5 22v-7l2-4h10l2 4v7"/></svg>',
  spinning: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="17" r="3"/><circle cx="18" cy="17" r="3"/><path d="M12 17V7l-3-3"/></svg>',
  yoga: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="3" r="1"/><path d="M8 20l4-8 4 8"/></svg>',
  pilates: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="4" r="2"/><path d="M8 20l4-6 4 6"/></svg>',
  crossfit: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 7V3H7v4"/></svg>',
  boxeo: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="8" r="5"/><circle cx="16" cy="8" r="5"/></svg>',
  zumba: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="4" r="2"/><path d="M12 6v12"/></svg>',
  parking: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="12" y="15" text-anchor="middle" font-size="10" font-weight="bold" fill="currentColor" stroke="none">P</text></svg>',
  guarderia: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/></svg>',
  cafeteria: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/></svg>',
  toallas: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18l-3 12H6L3 6z"/></svg>',
  taquillas: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/></svg>',
  wifi: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><circle cx="12" cy="20" r="1"/></svg>',
  app: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/></svg>',
  'abierto-24h': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
};
const facSVGsJSON = JSON.stringify(facSVGs);


---

<BaseLayout title="Gimnasios en Cataluña" currentPath="/gimnasios">
  <section class="res-section-tight" style="background:var(--color-white);">
    <div class="container-xl">
      <h1 style="margin-bottom:4px;" id="page-title">Gimnasios en Catalu&ntilde;a</h1>
      <p style="font-size:14px;font-weight:300;color:var(--color-mid-gray);" id="result-count">{allGyms.length} gimnasios</p>
      <p style="font-size:11px;font-weight:300;color:var(--color-mid-gray);margin-top:4px;line-height:1.4;max-width:600px;">
        Los costes var&iacute;an entre ofertas, temporadas y caracter&iacute;sticas del cliente. Esta p&aacute;gina muestra los precios bajo mi experiencia personal.
      </p>

      <!-- Filter Bar -->
      <div style="margin-top:16px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
        <input type="text" id="search-input" placeholder="Buscar por nombre o dirección..."
          style="flex:1;min-width:200px;padding:9px 14px;border:1px solid rgba(34,42,53,0.15);border-radius:var(--radius-8);font-size:14px;font-family:var(--font-body);outline:none;" />

        <button onclick="toggleFilters()" style="padding:9px 14px;border:1px solid rgba(34,42,53,0.15);border-radius:var(--radius-8);font-size:13px;cursor:pointer;background:white;white-space:nowrap;display:inline-flex;align-items:center;gap:4px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg> Filtros
        </button>

        <select id="city-select" style="padding:9px 12px;border:1px solid rgba(34,42,53,0.15);border-radius:var(--radius-8);font-size:13px;background:white;cursor:pointer;">
          <option value="">Toda Catalu&ntilde;a</option>
          {provinces.map(p => <option value={p}>{p}</option>)}
        </select>

        <select id="sort-select" style="padding:9px 12px;border:1px solid rgba(34,42,53,0.15);border-radius:var(--radius-8);font-size:13px;background:white;cursor:pointer;">
          <option value="relevance">Relevancia</option>
          <option value="price_asc">Menor precio</option>
          <option value="price_desc">Mayor precio</option>
        </select>

        <label style="display:flex;align-items:center;gap:6px;font-size:13px;padding:9px 12px;border:1px solid rgba(34,42,53,0.15);border-radius:var(--radius-8);cursor:pointer;background:white;white-space:nowrap;">
          <input type="checkbox" id="filter-24h" style="width:auto;" /> 24h
        </label>
      </div>

      <!-- Filter panel -->
      <div id="filter-panel" style="display:none;margin-top:10px;padding:14px;border:1px solid rgba(34,42,53,0.1);border-radius:var(--radius-8);background:white;">
        <div style="font-size:12px;font-weight:600;color:var(--color-mid-gray);margin-bottom:10px;">FILTRAR POR INSTALACIONES</div>
        <div id="filter-chips" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>

      <!-- Active filter chips -->
      <div id="active-filters" style="margin-top:10px;display:none;flex-wrap:wrap;gap:6px;align-items:center;"></div>
    </div>
  </section>

  <section style="padding:0 0 64px 0;background:var(--color-off-white);min-height:50vh;">
    <div class="container-xl">
      <div id="gym-grid" class="res-grid res-grid-3" style="gap:12px;overflow:hidden;"></div>
    </div>
  </section>

  <div id="gymcat-data" style="display:none;" data-gyms={gymsJSON} data-chains={chainsJSON} data-facs={facsJSON} data-facsvgs={facSVGsJSON}></div>
  <script src="/gym-list.js" defer></script>

  <!-- Geolocation: detect user city and update page title -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('gymcat_city');
      if (stored) {
        try {
          var c = JSON.parse(stored);
          if (c.province || c.city) updateTitle(c.province || c.city);
        } catch(e) {}
      }

      // Auto-detect if already consented
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(async function(pos) {
            try {
              var res = await fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + pos.coords.latitude + '&lon=' + pos.coords.longitude + '&zoom=10');
              var data = await res.json();
              var addr = data.address || {};
              var province = addr.state || '';
              var city = addr.city || addr.town || addr.village || '';
              var name = province || city;
              if (name) {
                localStorage.setItem('gymcat_city', JSON.stringify({ province: province, city: city }));
                updateTitle(name);
              }
            } catch(e) {}
          }, function(){}, { enableHighAccuracy: false, timeout: 5000 });
        }
      }

      function updateTitle(name) {
        var title = document.getElementById('page-title');
        if (title) title.innerHTML = 'Gimnasios en ' + name;
        document.title = 'Gimnasios en ' + name + ' | GymCat';
      }
    })();
  </script>
</BaseLayout>
