---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Gymcat — Comparador Inteligente de Gimnasios" description="Encuentra el gimnasio perfecto. Busca por precio, ubicación y servicios con IA.">
  <section class="bg-white" style="padding:64px 0 48px 0;">
    <div class="container-xl" style="text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:6px;border-radius:var(--radius-pill);padding:4px 14px;font-size:13px;font-weight:500;color:var(--color-mid-gray);background:var(--color-off-white);margin-bottom:20px;">
        <span style="width:7px;height:7px;border-radius:50%;background:#22c55e;display:inline-block;"></span> Beta — Datos actualizados semanalmente
      </div>
      <h1 style="margin-bottom:12px;">El gimnasio que buscas,<br/>sin letra pequeña.</h1>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);max-width:480px;margin:0 auto 24px;line-height:1.6;letter-spacing:-0.1px;">
        Compara precios reales, instalaciones y horarios de cientos de gimnasios en Cataluña. Datos actualizados por IA.
      </p>
      <div style="max-width:500px;margin:0 auto 20px;padding:14px 18px;background:var(--color-white);border-radius:var(--radius-12);box-shadow:var(--shadow-card);display:flex;align-items:center;gap:10px;cursor:text;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-mid-gray)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <div style="text-align:left;flex:1;">
          <span style="font-size:14px;color:var(--color-charcoal);display:block;">Buscar gimnasios...</span>
          <span style="font-size:12px;color:var(--color-mid-gray);">"con piscina cerca de Sants por menos de 40€"</span>
        </div>
        <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 7px;border-radius:var(--radius-4);color:var(--color-mid-gray);box-shadow:var(--shadow-ring-border);display:none;" class="hide-mobile">⌘K</kbd>
      </div>
      <div class="res-flex-col" style="justify-content:center;">
        <a href="/gimnasios" class="btn-primary" style="min-width:180px;text-decoration:none;text-align:center;">Explorar gimnasios</a>
        <a href="/vs" class="btn-ghost" style="min-width:140px;text-decoration:none;text-align:center;">Comparar VS</a>
      </div>
    </div>
  </section>

  <section style="padding:48px 0;background:var(--color-off-white);">
    <div class="container-xl">
      <div style="text-align:center;margin-bottom:32px;">
        <h2 style="margin-bottom:8px;">Transparencia que ningún<br class="hide-mobile"/>gimnasio te dará</h2>
        <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);max-width:420px;margin:0 auto;">Datos objetivos, sin marketing.</p>
      </div>
      <div class="res-grid-2" style="gap:12px;">
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="7" y1="21" x2="7" y2="9"/></svg><h3 style="margin-bottom:4px;">Historial de Precios</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Gráficos que muestran cómo han cambiado los precios. Detecta falsas ofertas al instante.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg><h3 style="margin-bottom:4px;">Coste Real a 12 Meses</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Matrícula + mensualidad + mantenimiento. Sin sorpresas.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg><h3 style="margin-bottom:4px;">Rese&ntilde;as con IA</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">DeepSeek analiza cientos de reseñas y extrae pros y contras reales.</p></div>
        <div class="card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-charcoal)" stroke-width="1.5" style="margin-bottom:8px;"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><h3 style="margin-bottom:4px;">Comparador VS</h3><p style="font-size:13px;font-weight:300;color:var(--color-mid-gray);line-height:1.5;">Dos gimnasios cara a cara. Precios, instalaciones y penalizaciones.</p></div>
      </div>
    </div>
  </section>

  <section style="padding:32px 0;border-top:1px solid rgba(34,42,53,0.08);border-bottom:1px solid rgba(34,42,53,0.08);">
    <div class="container-xl">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;text-align:center;">
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">17</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Gimnasios</div></div>
        <div><div style="font-size:28px;font-weight:600;font-family:var(--font-mono);color:var(--color-charcoal);">9</div><div style="font-size:12px;color:var(--color-mid-gray);margin-top:2px;">Cadenas</div></div>
      </div>
    </div>
  </section>

  <section style="padding:48px 0 64px 0;background:var(--color-white);">
    <div class="container-xl" style="text-align:center;">
      <h2 style="margin-bottom:8px;">¿Tienes un gimnasio?</h2>
      <p style="font-size:15px;font-weight:300;color:var(--color-mid-gray);margin-bottom:20px;">Añadimos tus datos sin coste.</p>
      <a href="mailto:hola@gymcat.es" class="btn-primary" style="min-width:180px;text-decoration:none;">Contactar &rarr;</a>
    </div>
  </section>
</BaseLayout>
